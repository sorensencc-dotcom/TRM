# Phase 4 Stage 1: Canary (10% rollout)
# Deploy to TRM harvester cluster

# Feature flag: Route 10% of image extraction to new Vision API implementation
ENABLE_IMAGE_ANALYSIS=0.1

# cic-ingestion service URL (must be accessible from TRM cluster)
CIC_INGESTION_URL=http://cic-ingestion:3000

# Vision API credentials (for real API calls)
VISION_API_KEY=${VISION_API_KEY}
GOOGLE_APPLICATION_CREDENTIALS=/etc/secrets/google-vision-sa.json

# Observability: Send metrics to monitoring system
METRICS_ENABLED=true
METRICS_PUSH_INTERVAL=60s

# Logging: Increase verbosity for canary monitoring
LOG_LEVEL=info
LOG_IMAGE_ANALYSIS_DETAILS=true

# Alerts: Page oncall on errors >5% for 5 min
ALERT_ERROR_RATE_THRESHOLD=0.05
ALERT_ERROR_RATE_WINDOW=300s

# Latency: Alert if p99 exceeds SLA
ALERT_LATENCY_P99_THRESHOLD=500
ALERT_LATENCY_P99_WINDOW=600s

# Fallback: Alert if Vision API fallback ratio exceeds threshold
ALERT_FALLBACK_RATIO_THRESHOLD=0.05
ALERT_FALLBACK_RATIO_WINDOW=900s

# Canary duration
CANARY_STAGE_DURATION=72h
