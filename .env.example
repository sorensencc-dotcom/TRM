# TRM environment variables

# cic-ingestion service configuration (Phase 2+)
# Required for real Vision API image analysis via HTTP
CIC_INGESTION_URL=http://localhost:3000

# Optional: override Vision API provider (currently 'google_vision' only)
# Leave unset to use default
VISION_API_PROVIDER=google_vision

# Optional: custom request timeout (milliseconds)
# Default: 5000ms (5s)
IMAGE_ANALYZER_TIMEOUT=5000

# Optional: request retry attempts
# Default: 3
IMAGE_ANALYZER_RETRIES=3
