{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["sources"],
  "additionalProperties": false,
  "properties": {
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "title", "origin", "url", "added_at", "actor"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string" },
          "title": { "type": "string" },
          "origin": { "type": "string" },
          "url": { "type": "string" },
          "added_at": { "type": "string" },
          "actor": { "type": "string" }
        }
      }
    }
  }
}
